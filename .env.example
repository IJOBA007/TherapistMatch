# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=sk_test_replace_with_your_rotated_key
PAYSTACK_PUBLIC_KEY=pk_test_replace_with_your_public_key

# Database & Storage
DATA_DIR=.

# Admin
# Public hosted admin URL path: /admin
# Admin console path after login: /tm-console-7f3a9c
ADMIN_SIGNUP_CODE=replace_with_a_private_code_for_creating_admins

# Email Verification
# Keep this off for demos unless SMTP is fully configured.
EMAIL_VERIFICATION_REQUIRED=0
# Set EMAIL_VERIFICATION_REQUIRED=1 if you want users and therapists to verify real email ownership before login.
APP_BASE_URL=https://your-render-app.onrender.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=TherapistMatch
SMTP_USE_SSL=0

# CORS Configuration (comma-separated URLs for production)
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Flask Configuration (set to 1 to enable debug mode, 0 for production)
FLASK_DEBUG=0

# Deployment Port (Render sets this automatically)
PORT=5000
